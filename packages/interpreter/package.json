{
  "name": "@emdzej/ediabasx-interpreter",
  "version": "0.1.2",
  "description": "BEST2 virtual machine: registers, flags, stacks, 184 opcodes, result sets — a TypeScript port of EdiabasLib`s C# core.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@emdzej/ediabasx-best-parser": "workspace:*",
    "@emdzej/ediabasx-core": "workspace:*",
    "@emdzej/ediabasx-interface-base": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "dev": "tsc -p tsconfig.json -w --preserveWatchOutput"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emdzej/ediabasx.git"
  }
}
