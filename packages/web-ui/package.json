{
  "name": "@emdzej/ediabasx-web-ui",
  "version": "0.4.0",
  "type": "module",
  "description": "Shared Svelte 5 components for ediabasx-family web apps — Connect button, Interface configuration panel. Source-only; consumer apps' Vite compiles them. Expects @emdzej/bimmerz-theme Tailwind preset applied.",
  "svelte": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "svelte": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "clean": "rm -rf .turbo *.tsbuildinfo"
  },
  "peerDependencies": {
    "@emdzej/bimmerz-theme": "^0.1.0",
    "svelte": "^5.0.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@tsconfig/svelte": "^5.0.4",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emdzej/ediabasx.git"
  }
}
