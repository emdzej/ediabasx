{
  "name": "@emdzej/ediabasx-interface-serial",
  "version": "0.2.1",
  "description": "Serial / K-line / K+DCAN transport (DS2 framing, KWP fast-init, ISO-TP) for the EdiabasX BEST2 interpreter.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "dev": "tsc -p tsconfig.json -w --preserveWatchOutput"
  },
  "dependencies": {
    "@emdzej/ediabasx-core": "workspace:*",
    "@emdzej/ediabasx-interface-base": "workspace:*",
    "@emdzej/ediabasx-protocol-uds": "workspace:*",
    "serialport": "^12.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emdzej/ediabasx.git"
  }
}
