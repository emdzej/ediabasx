{
  "name": "@emdzej/ediabasx-ediabas",
  "version": "0.1.0",
  "description": "Main EdiabasX library: load BMW PRG/GRP files, run BEST2 jobs against a configured transport, get back grouped result sets.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "dev": "tsc -p tsconfig.json -w --preserveWatchOutput"
  },
  "dependencies": {
    "@emdzej/ediabasx-best-parser": "workspace:*",
    "@emdzej/ediabasx-core": "workspace:*",
    "@emdzej/ediabasx-interface-base": "workspace:*",
    "@emdzej/ediabasx-interface-enet": "workspace:^",
    "@emdzej/ediabasx-interface-serial": "workspace:^",
    "@emdzej/ediabasx-interfaces": "workspace:^",
    "@emdzej/ediabasx-interpreter": "workspace:*",
    "@emdzej/ediabasx-logger": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "vitest": "^3.0.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emdzej/ediabasx.git"
  }
}
