{
  "name": "@emdzej/ediabasx-interfaces",
  "version": "0.4.2",
  "description": "Factory + JSON-RPC gateway server/client wiring all EdiabasX transports under a single `createInterface(name, opts)` entry point.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "dev": "tsc -p tsconfig.json -w --preserveWatchOutput"
  },
  "dependencies": {
    "@emdzej/ediabasx-interface-base": "workspace:*",
    "@emdzej/ediabasx-interface-enet": "workspace:*",
    "@emdzej/ediabasx-interface-j2534": "workspace:*",
    "@emdzej/ediabasx-interface-serial": "workspace:*",
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "@emdzej/j2534-driver": "^0.3.0",
    "@emdzej/j2534-types": "^0.3.0",
    "@emdzej/j2534-serial": "^0.3.0",
    "@emdzej/j2534-usb": "^0.3.0"
  },
  "peerDependenciesMeta": {
    "@emdzej/j2534-serial": { "optional": true },
    "@emdzej/j2534-usb": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "@types/ws": "^8.5.13"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emdzej/ediabasx.git"
  }
}
